# List directory contents
alias lsa='exa -lah --icons --git --sort=ext --sort=name --group-directories-first --ignore-glob=.DS_Store'
alias l='lsa'
alias ll='exa -lh --icons --git --sort=ext --sort=name --group-directories-first --ignore-glob=.DS_Store'
alias la='exa -lAh --icons --git --sort=ext --sort=name --group-directories-first --ignore-glob=.DS_Store'
